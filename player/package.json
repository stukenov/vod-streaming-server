{
  "private": true,
  "name": "player-server",
  "version": "1.11.3",
  "description": "Express.js video player server",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "build:client": "esbuild src/client/script.js --bundle --outfile=dist/public/script.js",
    "build:client:watch": "esbuild src/client/script.js --bundle --outfile=dist/public/script.js --watch",
    "build": "npm run clean && npm run build:client",
    "start": "node src/server.js",
    "dev:server": "nodemon src/server.js",
    "dev": "npm run build && concurrently \"npm run build:client:watch\" \"npm run dev:server\""
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.18.2",
    "hls-video-element": "^1.3.0",
    "mysql2": "^3.6.1",
    "player.style": "0.1.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "esbuild": "^0.25.0",
    "nodemon": "^3.0.3",
    "rimraf": "^5.0.5"
  }
}
